# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=adqip
POSTGRES_PASSWORD=adqip_secret
POSTGRES_DB=adqip
DATABASE_URL=postgresql+asyncpg://adqip:adqip_secret@postgres:5432/adqip

MONGO_USER=adqip
MONGO_PASSWORD=adqip_secret
MONGO_URL=mongodb://adqip:adqip_secret@mongo:27017/adqip?authSource=admin

REDIS_PASSWORD=adqip_secret
REDIS_URL=redis://:adqip_secret@redis:6379/0

# ── Object Storage (MinIO / S3) ───────────────────────────────────────────────
MINIO_ACCESS_KEY=adqip_minio
MINIO_SECRET_KEY=adqip_minio_secret
S3_ENDPOINT_URL=http://minio:9000
S3_DATASETS_BUCKET=adqip-datasets
S3_REPORTS_BUCKET=adqip-reports
AWS_ACCESS_KEY_ID=adqip_minio
AWS_SECRET_ACCESS_KEY=adqip_minio_secret
AWS_DEFAULT_REGION=us-east-1

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change_me_in_production_use_a_long_random_string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_TOPIC=adqip-stream
KAFKA_BATCH_WINDOW_SECONDS=5

# ── Pipeline ──────────────────────────────────────────────────────────────────
QUALITY_SCORE_ALERT_THRESHOLD=70
MAX_UPLOAD_SIZE_BYTES=2147483648
CELERY_BROKER_URL=redis://:adqip_secret@redis:6379/0
CELERY_RESULT_BACKEND=redis://:adqip_secret@redis:6379/1

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000
